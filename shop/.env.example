# Payload URL (used to fetch data)
# Public URL is for browser, Private is for server SSR (if different)
PAYLOAD_URL=http://localhost:3000
PAYLOAD_PRIVATE_URL=http://localhost:3000

# Site URL (used for sitemap, etc.)
SITE_URL=http://localhost:3001

# Google reCAPTCHA v3 (Invisible)
# Get keys from https://www.google.com/recaptcha/admin
# IMPORTANT: Select "reCAPTCHA v3" when creating the keys.
NUXT_PUBLIC_RECAPTCHA_SITE_KEY=your-v3-site-key
RECAPTCHA_SECRET_KEY=your-v3-secret-key

# Stripe Public Key
NUXT_PUBLIC_STRIPE_KEY=pk_test_...

# Google Analytics
# NUXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-...

# Payload API Key (server-only, for server-to-server calls like coupon validation)
# Generate this in Payload Admin → Users → your admin user → API Key tab
PAYLOAD_API_KEY=
